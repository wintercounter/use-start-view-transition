{
    "compilerOptions": {
        "module": "esNext",
        "target": "esnext",
        "moduleResolution": "bundler",
        "allowJs": false,
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "noImplicitAny": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "node_modules"]
}
